# Copy to .env and fill values (do NOT commit .env)
OPENAI_API_KEY=
USE_GOOGLE_VISION=false
GOOGLE_APPLICATION_CREDENTIALS=   # path to GCP JSON key if using Vision
JWT_SECRET=replace_with_a_strong_secret
ENCRYPTION_KEY=                        # Optional: base64 Fernet key. If blank, one will be generated on first run (demo only).
